{
    "printWidth": 100,
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "always",
    "overrides": [
        {
            "files": "*.php",
            "options": {
                "parser": "php",
                "tabWidth": 4,
                "singleQuote": true,
                "phpVersion": "8.2",
                "braceStyle": "1tbs"
            }
        },
        {
            "files": ["*.css", "*.scss"],
            "options": {
                "parser": "css",
                "tabWidth": 2,
                "singleQuote": false
            }
        },
        {
            "files": "*.js",
            "options": {
                "parser": "babel",
                "tabWidth": 2,
                "singleQuote": true
            }
        },
        {
            "files": ["*.html", "*.php"],
            "options": {
                "parser": "html",
                "htmlWhitespaceSensitivity": "css"
            }
        }
    ]
}
