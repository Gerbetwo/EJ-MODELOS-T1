<?php
/**
 * Formulario genérico para Crear/Editar registros.
 *
 * **Antes:** Usaba UI::ExceptionBox() y UI::Button() para generar HTML como strings.
 * **Ahora:** Todo el HTML vive aquí directamente como debe ser.
 *
 * **Seguridad XSS:**
 * Todos los valores que vienen de la BD ($rowData) se escapan con htmlspecialchars()
 * antes de insertarse en atributos HTML (value="...") o en texto.
 *
 * Variables disponibles (inyectadas desde Router::handleAjaxForm):
 * @var array  $columnsMeta Metadatos de las columnas
 * @var array  $rules       Reglas de validación (de Atributos PHP 8)
 * @var ?array $rowData     Datos del registro (null si es nuevo)
 * @var string $tableName   Slug de la tabla
 * @var bool   $isEdit      true si es edición
 * @var string $basePath    Ruta base
 * @var object $controller  Controlador para obtener opciones de relación
 */
declare(strict_types=1);

$safeBasePath = htmlspecialchars($basePath ?? '/', ENT_QUOTES, 'UTF-8');
$safeTableName = htmlspecialchars($tableName, ENT_QUOTES, 'UTF-8');
$actionUrl = $safeBasePath . $safeTableName . ($isEdit ? '/update' : '/create');
$formId = $isEdit ? 'form-update-dinamico' : 'form-create-dinamico';
?>

<form id="<?= htmlspecialchars($formId, ENT_QUOTES, 'UTF-8') ?>"
      class="form-ajax p-2"
      action="<?= htmlspecialchars($actionUrl, ENT_QUOTES, 'UTF-8') ?>"
      method="POST">

    <!-- Exception Box (antes era UI::ExceptionBox()) -->
    <div id="exception-container" class="d-none animate__animated animate__fadeIn">
        <div class="alert bg-glass-dark-custom border-danger text-white d-flex align-items-start"
             style="border-radius: 12px; border-left: 5px solid #ff4d4d !important;">
            <i class="fas fa-exclamation-circle text-danger mt-1 mr-3" style="font-size: 1.2rem;"></i>
            <div>
                <strong class="text-danger d-block mb-1">¡Ups! Revisa lo siguiente:</strong>
                <ul id="exception-list" class="mb-0 pl-3 small text-white-50"></ul>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <?php if ($isEdit): ?>
            <input type="hidden" name="id" value="<?= (int) $rowData['id'] ?>">
        <?php endif; ?>

        <?php foreach ($columnsMeta as $col):
            $rawName = $col['name'];

            // Saltar la columna ID y created_at
            if (strtolower($rawName) === 'id' || strtolower($rawName) === 'created_at') {
                continue;
            }

            $ruleKey = strtolower($rawName);
            $rule = $rules[$ruleKey] ?? [];
            $val = $isEdit ? htmlspecialchars((string) ($rowData[$rawName] ?? ''), ENT_QUOTES, 'UTF-8') : '';

            // Determinar tipo de input HTML
            $type = $rule['type'] ?? 'text';
            $htmlType = match ($type) {
                'email'  => 'email',
                'number' => 'number',
                'date'   => 'date',
                default  => 'text',
            };

            // Formatear fecha para input[type=date]
            if ($type === 'date' && !empty($val)) {
                $val = htmlspecialchars(date('Y-m-d', strtotime($val)), ENT_QUOTES, 'UTF-8');
            }
            $safeName = htmlspecialchars($rawName, ENT_QUOTES, 'UTF-8');
        ?>
            <div class="col-md-6">
                <div class="form-floating-custom">

                    <?php if ($type === 'relation'): ?>
                        <select name="<?= $safeName ?>" class="form-control" required>
                            <option value="" disabled <?= !$isEdit ? 'selected' : '' ?>>
                                <?= htmlspecialchars($rule['placeholder'] ?? 'Seleccione...', ENT_QUOTES, 'UTF-8') ?>
                            </option>
                            <?php
                            // Obtener opciones de la tabla referenciada
                            $displayCol = $rule['display'] ?? 'name';
                            $options = $controller->getExternalData(
                                $rule['references'] ?? '',
                                $displayCol,
                            );
                            foreach ($options as $opt): ?>
                                <option value="<?= (int) $opt['id'] ?>"
                                    <?= $val == (string) $opt['id'] ? 'selected' : '' ?>>
                                    <?= htmlspecialchars((string) $opt[$displayCol], ENT_QUOTES, 'UTF-8') ?>
                                </option>
                            <?php endforeach; ?>
                        </select>
                    <?php else: ?>
                        <input type="<?= htmlspecialchars($htmlType, ENT_QUOTES, 'UTF-8') ?>"
                               name="<?= $safeName ?>"
                               value="<?= $val ?>"
                               class="form-control"
                               placeholder=" "
                               required>
                    <?php endif; ?>

                    <label><?= htmlspecialchars(ucfirst($rawName), ENT_QUOTES, 'UTF-8') ?></label>
                    <small class="text-danger error-msg" id="error-<?= $safeName ?>"></small>
                </div>
            </div>
        <?php endforeach; ?>
    </div>

    <!-- Footer del modal (antes era UI::Button()) -->
    <div class="modal-footer border-0 px-0 pb-0 mt-2">
        <button type="button" class="btn btn-outline-secondary" data-dismiss="modal">Cancelar</button>
        <button type="submit"
                class="btn btn-brand px-4 shadow-sm"
                style="border-radius: 8px; font-weight: 600; transition: all 0.3s ease;">
            <i class="fas fa-save mr-2"></i>
            <?= $isEdit ? 'Actualizar Registro' : 'Crear Registro' ?>
        </button>
    </div>
</form>
