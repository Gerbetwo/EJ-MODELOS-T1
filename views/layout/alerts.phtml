<?php
/**
 * Componente de alertas flash.
 *
 * **Mejora respecto a la versión anterior:**
 * Antes el HTML se generaba con `echo` inline, incluyendo `$_GET['msg']` sin escapar.
 * Ahora usamos `match` expression de PHP 8.0+ y todo el output está escapado.
 *
 * **¿Qué es una alerta flash?**
 * Es un mensaje que se muestra una sola vez después de una acción (crear, eliminar).
 * Se pasa como parámetro GET (?msg=eliminado) y se consume al cargar la página.
 */
if (isset($_GET['msg'])) {
    $msgKey = $_GET['msg'];

    // match() es exhaustivo y más seguro que switch: solo acepta valores conocidos
    $alertData = match ($msgKey) {
        'creado'      => ['text' => 'Registro creado correctamente.',      'class' => 'alert-success'],
        'actualizado' => ['text' => 'Registro actualizado correctamente.', 'class' => 'alert-success'],
        'eliminado'   => ['text' => 'Registro eliminado correctamente.',   'class' => 'alert-success'],
        'error'       => ['text' => 'Ocurrió un error.',                   'class' => 'alert-danger'],
        default       => null,
    };

    if ($alertData !== null): ?>
        <div class="alert <?= htmlspecialchars($alertData['class'], ENT_QUOTES, 'UTF-8') ?> alert-dismissible fade show alert-custom" role="alert">
            <?= htmlspecialchars($alertData['text'], ENT_QUOTES, 'UTF-8') ?>
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true" style="color: white;">&times;</span>
            </button>
        </div>
    <?php endif;
}
