/**
 * Layout maestro de la aplicación.
 *
 * **¿Por qué .phtml?**
 * La extensión .phtml es la convención para vistas PHP que son principalmente HTML
 * con algo de PHP embebido (echo, foreach, if). Distingue visualmente los archivos
 * de vista de las clases PHP puras (.php) en src/.
 *
 * Variables disponibles (inyectadas desde public/index.php):
 * @var string $content      HTML del contenido principal
 * @var string $tableName    Slug del módulo activo (para títulos)
 * @var string $basePath     Ruta base para assets y links
 * @var array  $moduleSlugs  Lista de slugs para el sidebar
 */
declare(strict_types=1);

$pageTitle = htmlspecialchars(ucfirst($tableName ?? 'Dashboard'), ENT_QUOTES, 'UTF-8');
$safeBasePath = htmlspecialchars($basePath ?? '/', ENT_QUOTES, 'UTF-8');

// 1. Definición de rutas
$fileName = "adminlte.min.css";
$remoteUrl = "https://cdn.jsdelivr.net/npm/admin-lte@3.2.0/dist/css/adminlte.min.css";
$vendorRelPath = "assets/css/vendor/";
$vendorDir = $_SERVER['DOCUMENT_ROOT'] . '/' . ltrim($safeBasePath, '/') . $vendorRelPath;
$localFullPath = $vendorDir . $fileName;

// 2. Variable por defecto (Asumimos local, pero cambiaremos si falla)
$cssUrl = $safeBasePath . $vendorRelPath . $fileName;

// 3. Lógica de verificación y descarga
if (!file_exists($localFullPath) || filesize($localFullPath) < 1000) {
    
    // Intentar crear el directorio si no existe
    if (!is_dir($vendorDir)) {
        @mkdir($vendorDir, 0777, true);
    }

    $context = stream_context_create([
        "http" => ["header" => "User-Agent: Mozilla/5.0 (Windows NT 10.0; Win64; x64)\r\n"]
    ]);

    // Intentar descargar
    $downloadedContent = @file_get_contents($remoteUrl, false, $context);
    
    // Validamos: ¿Descargó algo? ¿Es contenido real de AdminLTE (> 10KB)?
    if ($downloadedContent !== false && strlen($downloadedContent) > 10000) {
        // Intentar guardar. Si falla el guardado (por permisos), usamos CDN.
        if (!@file_put_contents($localFullPath, $downloadedContent)) {
            $cssUrl = $remoteUrl;
        }
    } else {
        // Si falla la descarga o el contenido es muy pequeño (error 404 de la CDN, etc)
        $cssUrl = $remoteUrl;
    }
}
