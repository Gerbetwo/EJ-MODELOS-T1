<?php
/**
 * Vista genérica de listado — Fallback cuando no existe vista específica.
 *
 * Se usa cuando un módulo (ej. "orders") no tiene su propia carpeta
 * en views/. El Router cae aquí como fallback para generar la tabla automáticamente.
 *
 * @var array  $headers    Nombres de las columnas
 * @var array  $data       Datos del listado
 * @var string $tableName  Slug de la tabla
 * @var string $basePath   Ruta base
 */
declare(strict_types=1);

$safeTableName = htmlspecialchars($tableName ?? '', ENT_QUOTES, 'UTF-8');
$safeTitle = htmlspecialchars('Gestión de ' . ucfirst($tableName ?? ''), ENT_QUOTES, 'UTF-8');
$safeBasePath = htmlspecialchars($basePath ?? '/', ENT_QUOTES, 'UTF-8');
?>

<div class="card bg-surface border-glass shadow-glow">
    <div class="card-header d-flex align-items-center border-0">
        <h3 class="card-title text-brand mb-0"><?= $safeTitle ?></h3>
        <div class="card-tools ml-auto d-flex align-items-center">
            <div class="search-container mr-3">
                <div class="input-group input-group-sm" style="background: rgba(0,0,0,0.2); border-radius: 8px; border: 1px solid rgba(168, 85, 247, 0.3); padding: 2px 8px;">
                    <div class="input-group-prepend">
                        <span class="input-group-text bg-transparent border-0">
                            <i class="fas fa-search text-brand" style="font-size: 0.8rem;"></i>
                        </span>
                    </div>
                    <input type="text" id="tableSearch" class="form-control bg-transparent border-0 text-white"
                           placeholder="Filtrar datos..." style="box-shadow: none;">
                </div>
            </div>
            <button class="btn btn-brand btn-sm ml-2 btn-new-js"
                    data-table="<?= $safeTableName ?>">
                <i class="fas fa-plus mr-1"></i> Nuevo
            </button>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive" style="border-radius: 0 0 12px 12px; overflow: hidden;">
            <table id="dynamicTable" class="table table-borderless table-hover text-white-custom mb-0"
                   style="background: rgba(255,255,255,0.02);">
                <thead style="background: rgba(0,0,0,0.2); border-bottom: 1px solid rgba(168, 85, 247, 0.2);">
                    <tr>
                        <?php foreach ($headers as $h): ?>
                            <th class="text-accent py-3 px-4"
                                style="letter-spacing: 1px; font-size: 0.75rem; font-weight: 700;">
                                <?= htmlspecialchars(strtoupper($h), ENT_QUOTES, 'UTF-8') ?>
                            </th>
                        <?php endforeach; ?>
                        <th class="text-center text-accent py-3 px-4" style="font-size: 0.75rem;">ACCIONES</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <?php if (empty($data)): ?>
                        <tr>
                            <td colspan="<?= count($headers) + 1 ?>" class="text-center p-5 text-muted">
                                No se encontraron registros
                            </td>
                        </tr>
                    <?php endif; ?>

                    <?php foreach ($data as $row): ?>
                        <tr style="border-bottom: 1px solid rgba(255,255,255,0.03); transition: all 0.2s ease;">
                            <?php foreach ($headers as $h): ?>
                                <td class="py-3 px-4 align-middle"
                                    style="color: rgba(255,255,255,0.8); font-size: 0.9rem;">
                                    <?= htmlspecialchars((string) ($row[$h] ?? '-'), ENT_QUOTES, 'UTF-8') ?>
                                </td>
                            <?php endforeach; ?>
                            <td class="text-center align-middle">
                                <div class="btn-group">
                                    <button class="btn btn-xs btn-outline-brand mr-2 btn-edit-js"
                                            style="border-radius: 6px; width: 32px; height: 32px;"
                                            data-id="<?= (int) $row['id'] ?>"
                                            data-table="<?= $safeTableName ?>">
                                        <i class="fas fa-pen-nib"></i>
                                    </button>
                                    <button class="btn btn-xs btn-outline-danger btn-delete-js"
                                            style="border-radius: 6px; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;"
                                            data-id="<?= (int) $row['id'] ?>"
                                            data-table="<?= $safeTableName ?>">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
        </div>
    </div>
</div>
