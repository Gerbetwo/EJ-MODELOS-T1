<?php
/**
 * Vista de listado de Pedidos (Orders).
 *
 * Variables disponibles:
 * @var array  $data        Datos del listado
 * @var array  $columnsMeta Metadatos de las columnas
 * @var string $tableName   Slug de la tabla
 * @var string $basePath    Ruta base
 */
declare(strict_types=1);

$headers = array_column($columnsMeta, 'name');
$safeTableName = htmlspecialchars($tableName, ENT_QUOTES, 'UTF-8');
$safeTitle = htmlspecialchars(ucfirst($tableName), ENT_QUOTES, 'UTF-8');
$safeBasePath = htmlspecialchars($basePath ?? '/', ENT_QUOTES, 'UTF-8');
?>

<div class="card bg-surface border-glass shadow-glow">
    <div class="card-header d-flex align-items-center border-0">
        <h3 class="card-title text-brand mb-0">
            <i class="fas fa-shopping-cart mr-2"></i> Listado de <?= $safeTitle ?>
        </h3>
        <div class="card-tools ml-auto d-flex align-items-center">
            <!-- Buscador -->
            <div class="search-container mr-3">
                <div class="input-group input-group-sm data-table-search">
                    <div class="input-group-prepend">
                        <span class="input-group-text bg-transparent border-0">
                            <i class="fas fa-search text-brand"></i>
                        </span>
                    </div>
                    <input type="text" id="tableSearch" class="form-control bg-transparent border-0 text-white"
                           placeholder="Filtrar datos...">
                </div>
            </div>
            <!-- Botón Nuevo -->
            <button class="btn btn-brand btn-sm ml-2 btn-new-js"
                    data-table="<?= $safeTableName ?>">
                <i class="fas fa-plus mr-1"></i> Nuevo Pedido
            </button>
        </div>
    </div>

    <!-- Tabla -->
    <div class="card-body p-0">
        <div class="table-responsive data-table-wrapper">
            <table id="dynamicTable" class="table table-borderless table-hover text-white-custom mb-0 data-table">
                <thead>
                    <tr>
                        <?php foreach ($headers as $h): ?>
                            <th class="text-accent py-3 px-4">
                                <?= htmlspecialchars(strtoupper($h), ENT_QUOTES, 'UTF-8') ?>
                            </th>
                        <?php endforeach; ?>
                        <th class="text-center text-accent py-3 px-4">ACCIONES</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <?php if (empty($data)): ?>
                        <tr>
                            <td colspan="<?= count($headers) + 1 ?>"
                                class="text-center p-5 text-muted">
                                No se encontraron registros de pedidos.
                            </td>
                        </tr>
                    <?php endif; ?>

                    <?php foreach ($data as $row): ?>
                        <tr>
                            <?php foreach ($headers as $h): ?>
                                <td class="py-3 px-4 align-middle">
                                    <?= htmlspecialchars((string) ($row[$h] ?? '-'), ENT_QUOTES, 'UTF-8') ?>
                                </td>
                            <?php endforeach; ?>
                            <td class="text-center align-middle">
                                <div class="btn-group">
                                    <button class="btn btn-outline-brand mr-2 btn-edit-js action-btn"
                                            data-id="<?= (int) $row['id'] ?>"
                                            data-table="<?= $safeTableName ?>"
                                            title="Editar Pedido">
                                        <i class="fas fa-pen-nib"></i>
                                    </button>
                                    <button class="btn btn-outline-danger btn-delete-js action-btn"
                                            data-id="<?= (int) $row['id'] ?>"
                                            data-table="<?= $safeTableName ?>"
                                            title="Eliminar Pedido">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
        </div>
    </div>
</div>
