<?php
/**
 * Vista de error HTTP genérica (404, 500, etc.)
 *
 * Variables disponibles:
 * @var int    $statusCode   Código HTTP (404, 500, etc.)
 * @var string $errorMessage Mensaje descriptivo del error
 */
declare(strict_types=1);

$safeMessage = htmlspecialchars($errorMessage ?? 'Ha ocurrido un error.', ENT_QUOTES, 'UTF-8');
$safeCode = (int) ($statusCode ?? 500);

$icon = match (true) {
    $safeCode === 404 => 'fa-compass',
    $safeCode >= 500  => 'fa-exclamation-triangle',
    default           => 'fa-times-circle',
};

$title = match (true) {
    $safeCode === 404 => 'Página No Encontrada',
    $safeCode >= 500  => 'Error del Servidor',
    default           => 'Error',
};
?>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Error <?= $safeCode ?> | Gestión Udenar</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Importar estilos desde assets/css -->
    <link rel="stylesheet" href="/assets/css/error.css" />
</head>
<body>
    <div class="error-container">
        <div class="error-code"><?= $safeCode ?></div>
        <i class="fas <?= $icon ?> error-icon"></i>
        <h1 class="error-title"><?= htmlspecialchars($title, ENT_QUOTES, 'UTF-8') ?></h1>
        <p class="error-message"><?= $safeMessage ?></p>
        <a href="/" class="btn-home">
            <i class="fas fa-home mr-2"></i> Volver al Inicio
        </a>
    </div>
</body>
</html>



